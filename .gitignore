# .gitignore.open — staged for the open `precis-mcp` repo, published as
# .gitignore. Trimmed from the monorepo .gitignore to the open tree, with one
# deliberate inversion (see instance/ below).

# Virtual environment
.venv/

# Environment + secrets (runtime only, never committed)
.env
.env.*
# …but the committed template is the documented env contract (operators are
# told to copy deploy/.env.example) — re-include it past the .env.* ignore.
!.env.example
secrets/

# Python
__pycache__/
*.pyc
*.pyo

# Packaging build artefacts
build/
dist/
*.egg-info/

# Excel add-in local build artefacts (the Docker image builds dist/ from source).
node_modules/
excel-addin/node_modules/
excel-addin/dist/

# Test / tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# IDE
.idea/
.vscode/

# Office lock files
~$*

# NOTE: instance/ IS tracked here. The open repo ships a bundled demo fixture
# (the quickstart works from one clone). This inverts the monorepo, where
# instance/ is a separate repo and is gitignored.
