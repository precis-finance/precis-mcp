# Précis-MCP deploy bundle — copy to `deploy/.env` (git-ignored) and edit, or
# export these in your shell before `docker compose ... up`.
#
# Secrets: a plain value here is the simple default. For production, set the
# `<NAME>_FILE` variant instead (e.g. PGPASSWORD_FILE=/run/secrets/pgpassword
# with a Docker `secrets:` mount, a Kubernetes projected volume, or a Vault
# sidecar) — precis_mcp/secrets.py resolves it at startup. A plain value wins
# if both are set. Same mechanism in the open and Précis deployments.

# --- Deployment axes (which optional services this stack runs) -------------
# Data axis: `bundled-clickhouse` → this stack runs ClickHouse for you; leave
# it empty to run against your own (then set CHHOST below). Compose reads
# COMPOSE_PROFILES from --env-file; if your version doesn't, prefix it on the
# command instead.
#
# The friendly front door is `scripts/deploy-mcp.sh --data-mode MODE` (or the
# PRECIS_DATA_MODE env var), a preset over connection × provisioning:
#   byo            external ClickHouse (COMPOSE_PROFILES empty + CHHOST below);
#                  schema provisioned via `clickhouse_init`.
#   bundle-empty   bundled ClickHouse, schema-only (clickhouse_init) — empty,
#                  ready for your own ingestion.
#   bundle-sample  bundled ClickHouse, populated with synthetic eval data.
# It expands to COMPOSE_PROFILES + CHHOST here and runs the matching provisioner;
# the rare BYO-with-sample-data case is reachable by setting the two directly.
#
# Auth axis: `bundled-keycloak` → this stack runs Keycloak (mode B, default);
# drop it and set PRECIS_AUTH_MODE=oidc + the OIDC_* vars below for an external
# IdP (mode C). Front door: `scripts/deploy-mcp.sh --auth-mode keycloak|oidc`.
# The two axes are independent — COMPOSE_PROFILES is the combined list.
#
# Backup (optional, additive): append `backup` to COMPOSE_PROFILES to run the
# scheduler sidecar (config: instance/backup.yml; vars: Backups section below).
#
# Ingestion (optional, additive): append `ingestion` for the cron scheduler
# daemon, and `ingestion-watch` for the file-drop watcher (vars: Ingestion
# daemons section below).
#
# Ingress axis: `bundled-proxy` (default) → this stack runs Caddy on 80/443
# with automatic Let's Encrypt TLS for PRECIS_DOMAIN (set it below; needs
# public DNS + ports 80/443 reachable for the ACME challenge). Drop the
# profile to front the bundle's 127.0.0.1 ports with an ingress you already
# operate instead — reference nginx vhost in deploy/nginx/, host helper
# `scripts/install-precis-mcp.sh --nginx --domain yours.example.com`; the
# application is proxy-agnostic. Front door:
# `scripts/deploy-mcp.sh --ingress-mode bundled|byo`.
COMPOSE_PROFILES=bundled-clickhouse,bundled-keycloak,bundled-proxy
PRECIS_AUTH_MODE=keycloak

# --- Application image -----------------------------------------------------
# The app services pull ghcr.io/precis-finance/precis-mcp:${PRECIS_MCP_TAG} and
# fall back to building from source when it is absent (or on `up --build`).
# Defaults to the current release; pin a version or a digest for an immutable
# re-pull. PRECIS_EXTRAS bakes optional warehouse drivers at build time
# (comma-separated: bigquery,snowflake,mssql,databricks) — only used on the
# build-from-source path; empty means none.
# PRECIS_MCP_TAG=0.1.0
# PRECIS_EXTRAS=

# --- Required (local + remote) ---------------------------------------------
# Local single-user key. 32+ chars of entropy: `openssl rand -hex 32`.
MCP_DEV_KEY=

# --- ClickHouse read layer -------------------------------------------------
# CHUSER/CHPASSWORD/CHDATABASE seed the bundled service AND are the credentials
# precis-mcp connects with — keep them in sync if you point at your own.
CHUSER=precis
CHPASSWORD=precis
CHDATABASE=precis
# External ClickHouse (COMPOSE_PROFILES has no bundled-clickhouse): set the
# host/port reachable from the precis-mcp container, and CHUSER/CHPASSWORD to
# match. CHHOST defaults to the bundled service name `clickhouse`.
# CHHOST=clickhouse.internal.example.com
# CHPORT=8123

# --- Your model ------------------------------------------------------------
# Directory holding catalogue/, semantic/, integrations/. Defaults to the
# repo's bundled demo instance when unset.
# PRECIS_INSTANCE_DIR=/abs/path/to/instance

# --- Remote / multi-user (docker-compose.yml, Keycloak) --------------------
# Public origin of your server; the OAuth URLs and the /mcp audience derive
# from it (precis_mcp/oidc.py). Required for the remote bundle.
PRECIS_BASE_URL=https://precis.example.com
# Bare hostname for the bundled Caddy proxy (ingress axis above) — the host
# part of PRECIS_BASE_URL, no scheme. Required when `bundled-proxy` is in
# COMPOSE_PROFILES; ignored otherwise.
PRECIS_DOMAIN=precis.example.com
# KC_REALM=precis
# KC_MCP_AUDIENCE=            # defaults to ${PRECIS_BASE_URL}/mcp

# Platform Postgres (users, profiles, conversation history).
PGUSER=precis
PGPASSWORD=
# PLATFORM_DB_NAME=precis_platform

# Keycloak (mode B only — unused when PRECIS_AUTH_MODE=oidc) — bootstrap admin +
# the Keycloak DB role password (the realm-apply sidecar uses the admin creds).
# Use strong random values.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=
KC_DB_PASSWORD=

# External OIDC IdP (mode C — PRECIS_AUTH_MODE=oidc; drop bundled-keycloak from
# COMPOSE_PROFILES). The verifier points straight at your issuer; per-IdP setup
# (Auth0 / Okta / Entra / Ping) is in the deployment docs:
# deployment/external-idp-recipes.md.
# OIDC_ISSUER=https://your-idp.example.com/
# OIDC_JWKS_URL=                 # only if not derivable from issuer discovery
# OIDC_AUDIENCE=                 # the aud the /mcp resource requires
# OIDC_CLIENT_ID=                # your pre-registered client
# OIDC_CLIENT_SECRET=
# PRECIS_IDENTITY_CLAIM=         # signed claim carrying identity (default precis_user_id)
# PRECIS_IDENTITY_COLUMN=        # users column to match (id | external_id)

# --- Ingestion daemons (optional — COMPOSE_PROFILES+=ingestion[,ingestion-watch])
# `ingestion` runs the scheduler daemon (cron-triggered bindings);
# `ingestion-watch` additionally runs the file-drop watcher. Both read
# instance/integrations/ at process start — after editing sources/ or
# bindings/, restart: `docker compose restart ingestion-scheduler`.
# The per-binding lock is a Postgres advisory lock on the platform DB — no
# Redis.
#
# Per-source credentials (the `<SECRET_REF>_*` convention from
# instance/integrations/sources/) go in the `x-precis-env` block of
# docker-compose.yml, so they reach the server AND the daemons in one place.
# The *_FILE secret convention applies.
#
# Tick intervals (seconds):
# PRECIS_SCHEDULER_INTERVAL_SECONDS=60
# PRECIS_WATCHER_INTERVAL_SECONDS=30
#
# Drop stores for `trigger: watch` bindings — at least one for the watcher:
# Local-FS: the shared `ingest_dropbox` volume; the precis-mcp upload endpoint
# writes into it. Override the in-container path only if you know why:
# PRECIS_INGEST_UPLOAD_DIR=/data/ingest
# S3-compatible drop bucket:
# PRECIS_S3_BUCKET=
# PRECIS_S3_PREFIX=
# PRECIS_S3_REGION=
# PRECIS_S3_ENDPOINT_URL=
# PRECIS_S3_ACCESS_KEY_ID=
# PRECIS_S3_SECRET_ACCESS_KEY=
# SFTP drop:
# PRECIS_SFTP_HOST=
# PRECIS_SFTP_USER=
# PRECIS_SFTP_PASSWORD=
# PRECIS_SFTP_PORT=22
# PRECIS_SFTP_KEY_PATH=
# PRECIS_SFTP_PREFIX=

# --- Backups (optional — COMPOSE_PROFILES+=backup) --------------------------
# Declarative config lives in instance/backup.yml; full procedure in
# docs/operations/backups.md. Workflow: write backup.yml →
# `precis-mcp-admin backup init` (renders the ClickHouse backup-disk XML to
# deploy/secrets/precis_backup_disk.xml) → set PRECIS_BACKUP_CH_CONFIG to the
# rendered file → restart clickhouse → add `backup` to COMPOSE_PROFILES.
# PRECIS_BACKUP_CH_CONFIG=./secrets/precis_backup_disk.xml
#
# s3 destination credentials — these names follow the env-var-prefix refs in
# backup.yml (credentials.writer: BACKUP_WRITER / credentials.reader:
# BACKUP_READER). The *_FILE secret convention applies, and the writer/reader
# split matters: the writer identity must not be able to delete history (WORM
# bucket policy), the reader is for restore/list. Unused for a local destination.
# BACKUP_WRITER_ACCESS_KEY_ID=
# BACKUP_WRITER_SECRET_ACCESS_KEY=
# BACKUP_READER_ACCESS_KEY_ID=
# BACKUP_READER_SECRET_ACCESS_KEY=
#
# POSTed on any non-success run outcome (JSON: run_id, outcome, failed_stores).
# BACKUP_ALERT_WEBHOOK_URL=
#
# ClickHouse BACKUP/RESTORE command timeout in seconds (default 3600).
# PRECIS_BACKUP_CH_TIMEOUT=3600
